  "requiredPrivateInfos": [
    "chooseLocation"
  ],
  "tabBar": {
    "color": "#6B7280",
    "selectedColor": "#F97316",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "assets/tabbar/tab-home.png",
        "selectedIconPath": "assets/tabbar/tab-home-active.png"
      },
      {
        "pagePath": "pages/favorites/favorites",
        "text": "收藏",
        "iconPath": "assets/tabbar/tab-favorites.png",
        "selectedIconPath": "assets/tabbar/tab-favorites-active.png"
      },
      {
        "pagePath": "pages/orders/orders",
        "text": "订单",
        "iconPath": "assets/tabbar/tab-order.png",
        "selectedIconPath": "assets/tabbar/tab-order-active.png"
      },
      {
        "pagePath": "pages/messages/messages",
        "text": "消息",
        "iconPath": "assets/tabbar/tab-messages.png",
        "selectedIconPath": "assets/tabbar/tab-messages-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "assets/tabbar/tab-me.png",
        "selectedIconPath": "assets/tabbar/tab-me-active.png"
      }
