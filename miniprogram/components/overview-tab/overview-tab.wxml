<view class="overview-tab">
  <!-- 封面轮播图 (y=0, height=320px) -->
  <view class="overview-tab__cover">
    <swiper class="overview-tab__swiper" indicator-dots="{{true}}" autoplay circular>
      <swiper-item>
        <image class="overview-tab__cover-image" src="/images/store-detail/cover-image.jpg" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <!-- 实拍看房按钮 (112x80px) - 100% Figma还原 -->
    <view class="overview-tab__video-tour" bindtap="onVideoTour">
      <!-- 背景图片: 112x80px, 圆角8px, 2px白色边框 -->
      <!-- <image class="overview-tab__video-thumb" src="/images/store-detail/video-tour-bg.png" mode="aspectFill"></image> -->
      <!-- 遮罩层: 108x76px, 圆角6px, rgba(0,0,0,0.3) -->
      <image
        class="overview-tab__video-overlay"
        src="/images/store-detail/video-tour-overlay.svg"
        mode="aspectFit"
      ></image>
      <!-- 展开按钮: 20x20px, 圆形, rgba(0,0,0,0.5), x=88 y=4 -->
      <image class="overview-tab__expand-btn" src="/images/store-detail/video-expand-btn.svg" mode="aspectFit"></image>
    </view>

    <!-- 亮点标签条 (217x36px) - 可切换+动画 -->
    <view class="overview-tab__highlights">
      <!-- 高亮背景 - 动态位置 -->
      <view
        class="overview-tab__highlight-active"
        style="left: {{highlightLeft}}rpx; width: {{highlightWidth || 72}}rpx;"
      ></view>
      <!-- 标签项 -->
      <view
        wx:for="{{highlights}}"
        wx:key="id"
        class="overview-tab__highlight-item {{activeHighlightIndex === index ? 'overview-tab__highlight-item--active' : ''}}"
        data-index="{{index}}"
        bindtap="onHighlightTap"
      >
        <text
          class="overview-tab__highlight-text {{activeHighlightIndex === index ? 'overview-tab__highlight-text--active' : ''}}"
          >{{item.name}}</text
        >
        <image
          wx:if="{{item.hasArrow}}"
          class="overview-tab__arrow-icon"
          src="/images/store-detail/highlight-arrow.svg"
          mode="aspectFit"
        ></image>
      </view>
    </view>
  </view>

  <!-- 房屋基本信息卡片 (343x302px = 686x604rpx) -->
  <view class="overview-tab__info-card">
    <!-- 标题和分享 (y=16, 311x50px) -->
    <view class="overview-tab__info-header">
      <view class="overview-tab__title-wrap">
        <text class="overview-tab__title"
          >蜗壳精品店/深圳北大五居 家庭出游/麻将投影桌游/红山6979/过香港福田会展/山</text
        >
      </view>
      <view class="overview-tab__share-wrap">
        <image class="overview-tab__share-icon" src="/images/store-detail/icon-share.svg" mode="aspectFit"></image>
      </view>
    </view>

    <!-- 蜗壳精选标签 (y=82, 311x44px) -->
    <view class="overview-tab__quality-badge">
      <view class="overview-tab__quality-tag">
        <text>蜗壳精选</text>
      </view>
      <view class="overview-tab__quality-content">
        <text class="overview-tab__quality-text">实拍视频有保障, 入住不满意必赔</text>
      </view>
      <image
        class="overview-tab__quality-arrow"
        src="/images/store-detail/icon-angle-right-gray.svg"
        mode="aspectFit"
      ></image>
    </view>

    <!-- 特色标签 (y=142, 311x60px) -->
    <view class="overview-tab__feature-tags">
      <view class="overview-tab__feature-tag">专业保洁</view>
      <view class="overview-tab__feature-tag">网红INS风</view>
      <view class="overview-tab__feature-tag">实拍看房</view>
      <view class="overview-tab__feature-tag">免费瓶装水</view>
      <view class="overview-tab__feature-tag">干湿分离</view>
      <view class="overview-tab__feature-tag">5星卫生分</view>
    </view>

    <!-- 底部区域: 评分卡片 + 地址区域 (y=218) -->
    <view class="overview-tab__bottom-section">
      <!-- 评分卡片 (x=16, 114x68px) -->
      <view class="overview-tab__rating-card" bindtap="onViewReviews">
        <view class="overview-tab__rating-header">
          <image
            class="overview-tab__star-icon"
            src="/images/store-detail/icon-star-orange.svg"
            mode="aspectFit"
          ></image>
          <view class="overview-tab__rating-info">
            <text class="overview-tab__rating-score">5.0超棒</text>
          </view>
          <view class="overview-tab__rating-count-wrap">
            <text class="overview-tab__rating-count">20条 </text>
          </view>
          <image
            class="overview-tab__rating-arrow"
            src="/images/store-detail/icon-angle-right-rating.svg"
            mode="aspectFit"
          ></image>
        </view>
        <view class="overview-tab__rating-comment">
          <text>"室内干净整洁"</text>
        </view>
      </view>

      <!-- 地址区域 (x=138, 197x68px) -->
      <view class="overview-tab__address-section" bindtap="onViewMap">
        <image class="overview-tab__map-bg" src="/images/store-detail/map-thumbnail.jpg" mode="aspectFill"></image>
        <view class="overview-tab__address-content">
          <text class="overview-tab__address-text"
            >距深圳北站-深圳北站-A1出站口(东1号出站口)直线1.9公里 龙华区, 深圳龙华区龙光玖钻北区-1A...</text
          >
        </view>
        <view class="overview-tab__map-link">
          <image class="overview-tab__map-icon" src="/images/store-detail/icon-map-circle.svg" mode="aspectFit"></image>
          <text class="overview-tab__map-text">地图</text>
        </view>
      </view>
    </view>
  </view>
</view>
