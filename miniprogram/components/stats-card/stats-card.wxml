<view class="card" aria-label="个人数据">
  <view class="row">
    <view class="cell" bindtap="onCoupon" aria-role="button" aria-label="优惠券">
      <image class="icon" src="/assets/figma/stat-coupon.svg" mode="aspectFit" />
      <text class="text">优惠券</text>
      <text class="count">{{couponCount}}</text>
    </view>

    <view class="divider-v" aria-hidden="true"></view>

    <view class="cell" bindtap="onFavorites" aria-role="button" aria-label="收藏浏览">
      <image class="icon" src="/assets/figma/stat-star.svg" mode="aspectFit" />
      <text class="text">收藏浏览</text>
    </view>

    <view class="divider-v" aria-hidden="true"></view>

    <view class="cell" bindtap="onPoints" aria-role="button" aria-label="积分">
      <image class="icon" src="/assets/figma/stat-coins.svg" mode="aspectFit" />
      <text class="text">积分</text>
    </view>
  </view>

  <view class="divider-h" aria-hidden="true"></view>

  <quick-actions bind:action="onTapQuickAction" />
</view>
