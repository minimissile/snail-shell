<view class="tabbar" aria-label="底部导航">
  <view class="tabbar__inner">
    <view
      wx:for="{{items}}"
      wx:key="key"
      class="tabbar__item {{active === item.key ? 'is-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTap"
      aria-role="button"
      aria-label="{{item.label}}"
    >
      <image class="tabbar__icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="tabbar__label">{{item.label}}</text>
    </view>
  </view>
</view>
