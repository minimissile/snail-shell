<view class="favorites-page">
  <!-- 标签栏 -->
  <view class="tabs-container">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab-item {{activeTab === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTabChange"
    >
      <text class="tab-label">{{item.label}}</text>
      <view wx:if="{{activeTab === item.id}}" class="tab-indicator"></view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view class="content-container" scroll-y enhanced>
    <!-- 今天标题 (仅足迹页显示) -->
    <view wx:if="{{activeTab === 'footprints'}}" class="section-title">
      <text class="title-text">{{todayLabel}}</text>
    </view>

    <!-- 收藏列表 -->
    <view wx:if="{{activeTab === 'favorites'}}" class="cards-list">
      <view wx:for="{{favoritesList}}" wx:key="id" class="card-item" data-id="{{item.id}}" bindtap="onCardTap">
        <view class="card-image">
          <image src="{{item.image}}" mode="aspectFill" class="image" />
          <view class="tag-badge">
            <text class="tag-text">{{item.tag}}</text>
          </view>
        </view>
        <view class="card-info">
          <view class="info-title">
            <text class="title">{{item.title}}</text>
          </view>
          <view class="info-rating">
            <text class="rating-value">{{item.rating}}</text>
            <text class="rating-unit">分</text>
            <text class="review-count">{{item.reviewCount}}人评价</text>
          </view>
          <view class="info-location">
            <text class="location">{{item.location}}</text>
          </view>
          <view class="info-footer">
            <view class="check-in">
              <text class="check-in-text">{{item.checkInDate}}</text>
            </view>
            <view class="price-box">
              <text class="price-unit">¥</text>
              <text class="price-value">{{item.price}}</text>
              <text class="price-label">起</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 足迹列表 -->
    <view wx:if="{{activeTab === 'footprints'}}" class="cards-list">
      <view wx:for="{{footprintsList}}" wx:key="id" class="card-item" data-id="{{item.id}}" bindtap="onCardTap">
        <view class="card-image">
          <image src="{{item.image}}" mode="aspectFill" class="image" />
          <view class="tag-badge">
            <text class="tag-text">{{item.tag}}</text>
          </view>
        </view>
        <view class="card-info">
          <view class="info-title">
            <text class="title">{{item.title}}</text>
          </view>
          <view class="info-rating">
            <text class="rating-value">{{item.rating}}</text>
            <text class="rating-unit">分</text>
            <text class="review-count">{{item.reviewCount}}人评价</text>
          </view>
          <view class="info-location">
            <text class="location">{{item.location}}</text>
          </view>
          <view class="info-footer">
            <view class="check-in">
              <text class="check-in-text">{{item.checkInDate}}</text>
            </view>
            <view class="price-box">
              <text class="price-unit">¥</text>
              <text class="price-value">{{item.price}}</text>
              <text class="price-label">起</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 没有更多了 -->
    <view class="no-more">
      <text class="no-more-text">没有更多了</text>
    </view>
  </scroll-view>
</view>

<!-- 智能开锁浮动按钮 -->
<!-- <floating-lock-button /> -->

<!-- 登录弹窗 -->
<login-popup
  visible="{{showLoginPopup}}"
  bind:visiblechange="onLoginPopupVisibleChange"
  bind:loginsuccess="onLoginSuccess"
/>
