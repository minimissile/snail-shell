<view class="store-detail">
  <!-- 封面部分 -->
  <view class="cover">
    <image class="cover__image" src="{{coverImage}}" mode="aspectFill" />

    <!-- 状态栏 -->
    <view class="cover__status-bar">
      <text class="cover__time">9:41</text>
      <view class="cover__icons">
        <view class="cover__icon-cell"></view>
        <view class="cover__icon-wifi"></view>
        <view class="cover__icon-battery"></view>
      </view>
    </view>

    <!-- 返回按钮和收藏按钮 -->
    <view class="cover__actions">
      <view class="cover__back" bindtap="onGoBack">
        <text class="cover__back-icon">‹</text>
      </view>
      <view class="cover__favorites">
        <view class="cover__favorite-btn" bindtap="onToggleFavorite">
          <text class="cover__favorite-icon">{{isFavorite ? '' : ''}}</text>
        </view>
        <view class="cover__favorite-count">
          <text class="cover__favorite-count-text">{{favoriteCount}}</text>
        </view>
      </view>
    </view>

    <!-- 实拍看房 -->
    <view class="cover__video" bindtap="onViewVideo">
      <image class="cover__video-thumbnail" src="{{videoThumbnail}}" mode="aspectFill" />
      <view class="cover__video-overlay">
        <text class="cover__video-icon"></text>
        <text class="cover__video-text">实拍看房</text>
      </view>
      <view class="cover__video-expand">
        <text class="cover__expand-icon"></text>
      </view>
    </view>

    <!-- 图片分类标签 -->
    <view class="cover__tabs">
      <view class="cover__tab cover__tab--active">
        <text class="cover__tab-text">封面</text>
      </view>
      <text class="cover__tab-text">WOW亮点!</text>
      <text class="cover__tab-text">卧室</text>
      <text class="cover__tab-text">厨房｜</text>
      <view class="cover__tab-more">
        <text class="cover__tab-text">相册</text>
        <text class="cover__tab-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 房屋基本信息 -->
  <view class="info">
    <view class="info__header">
      <text class="info__title">{{propertyTitle}}</text>
      <text class="info__star"></text>
    </view>

    <!-- 地址信息 -->
    <view class="info__address">
      <image class="info__address-bg" src="{{mapThumbnail}}" mode="aspectFill" />
      <text class="info__address-text">{{address}}</text>
      <view class="info__map" bindtap="onViewMap">
        <text class="info__map-icon"></text>
        <text class="info__map-text">地图</text>
      </view>
    </view>

    <!-- 蜗壳精选标签 -->
    <view class="info__selected" bindtap="onViewSelectedTag">
      <view class="info__selected-badge">
        <text class="info__selected-badge-text">蜗壳精选</text>
      </view>
      <text class="info__selected-desc">实拍视频有保障, 入住不满意必赔</text>
      <text class="info__selected-arrow">›</text>
    </view>

    <!-- 标签列表 -->
    <view class="info__tags">
      <view class="info__tag" wx:for="{{tags}}" wx:key="index">
        <text class="info__tag-text">{{item}}</text>
      </view>
    </view>

    <!-- 评分信息 -->
    <view class="info__rating" bindtap="onViewReviews">
      <view class="info__rating-content">
        <text class="info__rating-star"></text>
        <text class="info__rating-score">{{rating}}超棒</text>
        <text class="info__rating-count">{{reviewCount}}条</text>
        <text class="info__rating-arrow">›</text>
      </view>
      <view class="info__rating-comment">
        <text class="info__rating-comment-text">"{{highlightComment}}"</text>
      </view>
    </view>
  </view>

  <!-- 入住时间 -->
  <view class="checkin">
    <view class="checkin__item">
      <text class="checkin__date">{{checkInDate}}</text>
      <text class="checkin__day">{{checkInDay}} 入住</text>
    </view>
    <view class="checkin__item">
      <text class="checkin__date">{{checkOutDate}}</text>
      <text class="checkin__day">{{checkOutDay}} 离开</text>
    </view>
    <view class="checkin__nights" bindtap="onChangeDate">
      <text class="checkin__nights-text">共{{totalNights}}晚</text>
    </view>
  </view>

  <!-- 金刚区 -->
  <view class="diamond">
    <view
      class="diamond__item"
      wx:for="{{diamondItems}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onDiamondItemTap"
      style="background: {{item.bgColor}}"
    >
      <text class="diamond__title">{{item.title}}</text>
      <text class="diamond__subtitle">{{item.subtitle}}</text>
      <view class="diamond__circle diamond__circle--1" style="background: {{item.circleColor1}}"></view>
      <view class="diamond__circle diamond__circle--2" style="background: {{item.circleColor2}}"></view>
      <image class="diamond__icon" src="{{item.icon}}" mode="aspectFit" />
    </view>
  </view>

  <!-- 优惠券横幅 -->
  <view class="coupon" bindtap="onViewCoupon">
    <view class="coupon__badge">
      <text class="coupon__amount">¥200</text>
    </view>
    <text class="coupon__text">连住专享券</text>
    <view class="coupon__action">
      <text class="coupon__action-text">查看</text>
      <text class="coupon__action-arrow">›</text>
    </view>
  </view>

  <!-- 房型详情 -->
  <view class="room">
    <image class="room__image" src="{{roomImage}}" mode="aspectFill" />
    <view class="room__content">
      <view class="room__header" bindtap="onViewRoomDetails">
        <text class="room__type">{{roomType}}</text>
        <text class="room__arrow">›</text>
      </view>
      <text class="room__details">{{roomDetails}}</text>
      <text class="room__rule">{{checkInRule}}</text>

      <view class="room__price">
        <view class="room__price-tag">
          <text class="room__price-tag-text">立即确认</text>
        </view>
        <view class="room__price-info">
          <view class="room__price-group">
            <text class="room__price-original">¥{{originalPrice}}</text>
            <text class="room__price-current">¥{{currentPrice}}</text>
          </view>
          <view class="room__price-badge">
            <view class="room__price-badge-left"></view>
            <view class="room__price-badge-right"></view>
            <view class="room__price-saved" bindtap="onViewSavedAmount">
              <text class="room__price-saved-text">已省¥{{savedAmount}}</text>
              <text class="room__price-saved-arrow">›</text>
            </view>
            <text class="room__price-label">首单特惠</text>
          </view>
        </view>
        <view class="room__book-btn" bindtap="onBookNow">
          <text class="room__book-text">订</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部预订栏 -->
  <view class="footer">
    <view class="footer__date" bindtap="onChangeDate">
      <text class="footer__date-text">住 11-19</text>
      <text class="footer__date-text">离 11-20</text>
      <text class="footer__date-arrow">‹</text>
    </view>
    <view class="footer__actions">
      <view class="footer__btn footer__btn--outline" bindtap="onRealSceneRoomSelection">
        <text class="footer__btn-text">实景选房</text>
      </view>
      <view class="footer__btn footer__btn--primary" bindtap="onBookNow">
        <text class="footer__btn-text">立即预订</text>
        <view class="footer__price">
          <text class="footer__price-current">¥{{currentPrice}}</text>
          <text class="footer__price-original">¥{{originalPrice}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
