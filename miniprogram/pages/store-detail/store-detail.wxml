<view class="store-detail">
  <!-- 状态栏 (y=0, height=44.32px) -->
  <view class="store-detail__status-bar">
    <view class="store-detail__status-bar-bg"></view>
    <view class="store-detail__status-content">
      <text class="store-detail__status-time">9:41</text>
      <view class="store-detail__status-icons">
        <view class="store-detail__status-cellular"></view>
        <view class="store-detail__status-wifi"></view>
        <view class="store-detail__status-battery"></view>
      </view>
    </view>
  </view>

  <!-- Header (y=45px, padding=10px 0px) -->
  <view class="store-detail__header">
    <!-- Header Actions (padding=10px 0px) -->
    <view class="store-detail__header-actions">
      <!-- Go back button (32x32px) -->
      <view class="store-detail__back-btn" bindtap="onGoBack">
        <image class="store-detail__back-icon" src="/images/store-detail/angle-left.svg" mode="aspectFit"></image>
      </view>

      <!-- Right actions group (width=215px) -->
      <view class="store-detail__actions-group">
        <!-- 收藏组 (width=56px, height=49px) -->
        <view class="store-detail__favorite-wrapper">
          <!-- Like button (40x40px, x=0, y=9) -->
          <view class="store-detail__favorite-btn" bindtap="onToggleFavorite">
            <text class="store-detail__favorite-icon">{{isFavorite ? '♥' : '♡'}}</text>
          </view>
          <!-- Badge (34x22px, x=22, y=0) -->
          <view class="store-detail__favorite-badge">
            <text class="store-detail__favorite-count">{{favoriteCount}}</text>
          </view>
        </view>

        <!-- WeChat button (87x32px, x=128, y=9) -->
        <view class="store-detail__wechat-btn" bindtap="onOpenWechat">
          <view class="store-detail__wechat-bg"></view>
          <view class="store-detail__wechat-icon"></view>
        </view>
      </view>
    </view>

    <!-- 标签导航栏 - 使用 TDesign Tabs 组件 -->
    <t-tabs value="{{activeTab}}" bind:change="onTabChange" theme="line" class="store-detail__tabs">
      <t-tab-panel wx:for="{{tabs}}" wx:key="id" label="{{item.name}}" value="{{item.id}}" />
    </t-tabs>
  </view>

  <!-- Container (y=157px, padding=16px) -->
  <view class="store-detail__container">
    <!-- Feature Card - 特点卡片 (height=618px, border-radius=12px) -->
    <view class="store-detail__feature-card" wx:if="{{activeTab === 'feature'}}">
      <!-- Header - 房屋特色 (x=16, y=16) -->
      <view class="store-detail__feature-header">
        <text class="store-detail__feature-title">房屋特色</text>
      </view>

      <!-- Title with Icon (x=143, y=232) -->
      <view class="store-detail__feature-name-wrapper">
        <image class="store-detail__snail-icon" src="/images/store-detail/snail-icon.png" mode="aspectFit"></image>
        <text class="store-detail__feature-name">蜗壳青旅</text>
      </view>

      <!-- Description Text (x=32, y=268, width=311px, height=351px) -->
      <view class="store-detail__feature-description">
        <text class="store-detail__feature-text">
          蜗壳青旅是一处为旅人打造的静心居所，我们希望每一位入住者都能在城市的节奏中找到片刻宁静。四人位安静区房型，专为好友出行或轻度社交旅客设计，在共享空间中保留足够的私密与安静。
        </text>
        <text class="store-detail__feature-text">
          房间面积约二十六平方米，设有两组上下铺，可同时容纳四位客人。每个床位配备独立阅读灯、隐私帘和储物柜，床垫柔软舒适，床品干净整洁。房间采用原木与米色调的简约设计风格，光线柔和，空气清新，让人放松安心。
        </text>
        <text class="store-detail__feature-text">
          该房型位于青旅的安静楼层，远离街道与公共活动区，使用静音门锁和隔音墙体，确保夜间安睡无扰。房间配备空调、新风系统和高速无线网络，并提供公共卫浴设施，每日定时清洁。
        </text>
      </view>

      <!-- Feature Image (x=26, y=635, width=317px, height=211px) -->
      <view class="store-detail__feature-image-wrapper">
        <image
          class="store-detail__feature-image"
          src="/images/store-detail/feature-image.png"
          mode="aspectFill"
        ></image>
      </view>

      <!-- Blur Background (x=24, y=696, width=317px, height=118px) -->
      <view class="store-detail__feature-blur"></view>

      <!-- View All Button (x=138, y=760) -->
      <view class="store-detail__feature-expand" bindtap="onExpandFeature">
        <text class="store-detail__feature-expand-text">展开查看全部 </text>
        <image class="store-detail__angle-down-icon" src="/images/store-detail/angle-down.svg" mode="aspectFit"></image>
      </view>
    </view>

    <!-- Facility Card - 设施卡片 -->
    <view class="store-detail__facility-card" wx:if="{{activeTab === 'facility'}}">
      <!-- Header - 服务/设施 (padding=16px) -->
      <view class="store-detail__facility-header">
        <text class="store-detail__facility-title">服务/设施</text>
        <view class="store-detail__facility-link" bindtap="onViewAllFacilities">
          <text class="store-detail__facility-link-text">全部设施 </text>
          <image
            class="store-detail__arrow-right-icon"
            src="/images/store-detail/angle-right-small.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>

      <!-- 服务 Section -->
      <view class="store-detail__facility-section">
        <view class="store-detail__facility-category">
          <text class="store-detail__facility-category-title">服务</text>
        </view>
        <view class="store-detail__facility-items">
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">免费停车位</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">付费停车位</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">行李寄存</text>
          </view>
        </view>
      </view>

      <!-- 基础 Section -->
      <view class="store-detail__facility-section">
        <view class="store-detail__facility-category">
          <text class="store-detail__facility-category-title">基础</text>
        </view>
        <view class="store-detail__facility-items">
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">无线网络</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">电梯</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">窗户</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">空调-冷暖</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">暖气</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">凉衣架</text>
          </view>
        </view>
      </view>

      <!-- 卫浴 Section -->
      <view class="store-detail__facility-section">
        <view class="store-detail__facility-category">
          <text class="store-detail__facility-category-title">卫浴</text>
        </view>
        <view class="store-detail__facility-items">
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">热水</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">独立卫浴</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">电吹风</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">洗浴用品</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--available"
              src="/images/store-detail/check-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">牙具</text>
          </view>
          <view class="store-detail__facility-item">
            <image
              class="store-detail__facility-icon store-detail__facility-icon--unavailable"
              src="/images/store-detail/xmark-circle-regular.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__facility-text">浴巾</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Landlord Card - 房东介绍卡片 -->
    <view class="store-detail__landlord-card" wx:if="{{activeTab === 'landlord'}}">
      <!-- Header - 房东介绍 -->
      <view class="store-detail__landlord-header">
        <text class="store-detail__landlord-title">房东介绍</text>
        <view class="store-detail__landlord-link" bindtap="onViewLandlordPage">
          <text class="store-detail__landlord-link-text">房东主页 </text>
          <image
            class="store-detail__arrow-right-icon"
            src="/images/store-detail/angle-right-small.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>

      <!-- Landlord Info -->
      <view class="store-detail__landlord-info">
        <view class="store-detail__landlord-profile">
          <image
            class="store-detail__landlord-avatar"
            src="/images/store-detail/landlord-avatar.svg"
            mode="aspectFit"
          ></image>
          <view class="store-detail__landlord-details">
            <text class="store-detail__landlord-name">蜗壳旗舰店</text>
            <view class="store-detail__landlord-badge">
              <text class="store-detail__landlord-badge-text">自然人房东｜实名验证｜1套房屋</text>
            </view>
          </view>
        </view>
        <view class="store-detail__landlord-contact" bindtap="onContactLandlord">
          <text class="store-detail__landlord-contact-text">联系房东</text>
        </view>
      </view>

      <!-- Landlord Stats -->
      <view class="store-detail__landlord-stats">
        <view class="store-detail__landlord-stat-row">
          <view class="store-detail__landlord-stat-item">
            <text class="store-detail__landlord-stat-label">好评率</text>
          </view>
          <view class="store-detail__landlord-stat-item">
            <text class="store-detail__landlord-stat-value">暂无</text>
          </view>
          <view class="store-detail__landlord-stat-item">
            <text class="store-detail__landlord-stat-subtitle">共30条点评</text>
          </view>
        </view>
        <view class="store-detail__landlord-stat-row">
          <view class="store-detail__landlord-stat-item">
            <text class="store-detail__landlord-stat-label">订单确认率</text>
          </view>
          <view class="store-detail__landlord-stat-item">
            <text class="store-detail__landlord-stat-value store-detail__landlord-stat-value--highlight">100%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Process Card - 体验流程卡片 (简版) -->
    <view class="store-detail__process-simple-card" wx:if="{{activeTab === 'landlord'}}">
      <!-- Header - 体验流程 -->
      <view class="store-detail__process-simple-header">
        <text class="store-detail__process-simple-title">体验流程</text>
        <view class="store-detail__process-simple-link" bindtap="onViewAllProcess">
          <text class="store-detail__process-simple-link-text">全部流程 </text>
          <image
            class="store-detail__arrow-right-icon"
            src="/images/store-detail/angle-right-small.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>

      <!-- Tip -->
      <view class="store-detail__process-simple-tip">
        <view class="store-detail__info-icon-wrapper">
          <text class="store-detail__info-icon-text"></text>
        </view>
        <text class="store-detail__process-simple-tip-text">以下规则由房东制定，请仔细阅读并遵守</text>
      </view>
    </view>

    <!-- Background Card (height=336px, border-radius=12px) -->
    <view class="store-detail__cost-card" wx:if="{{activeTab === 'cost'}}">
      <!-- Header (x=16, y=16, width=311px) -->
      <view class="store-detail__cost-header">
        <view class="store-detail__cost-title-wrapper">
          <text class="store-detail__cost-title">费用须知</text>
        </view>
        <view class="store-detail__cost-link" bindtap="onViewAllRules">
          <text class="store-detail__cost-link-text">全部须知</text>
          <image
            class="store-detail__arrow-right-icon"
            src="/images/store-detail/angle-right-small.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>

      <!-- Tip container (x=16, y=52, width=311px) -->
      <view class="store-detail__cost-tip">
        <view class="store-detail__info-icon-wrapper">
          <image class="store-detail__info-icon" src="/images/store-detail/info-circle.svg" mode="aspectFit"></image>
        </view>
        <text class="store-detail__cost-tip-text">以下规则由房东制定，请仔细阅读并遵守</text>
      </view>

      <!-- Rules container (x=16, y=76, width=311px, height=120px, padding=12px 0px) -->
      <view class="store-detail__rules-container">
        <!-- 押金 -->
        <view class="store-detail__rule-row">
          <view class="store-detail__rule-label-wrapper">
            <text class="store-detail__rule-label">押金</text>
          </view>
          <view class="store-detail__rule-content">
            <image
              class="store-detail__info-circle-icon"
              src="/images/store-detail/info-circle.svg"
              mode="aspectFit"
            ></image>
            <text class="store-detail__rule-text"
              >¥200，下单后入住前通过平台支付，离店后{{'\n'}}原路退还，无纠纷不扣押</text
            >
          </view>
        </view>

        <!-- Line (width=311px, height=1px) -->
        <view class="store-detail__rule-divider"></view>

        <!-- 加人 -->
        <view class="store-detail__rule-row">
          <view class="store-detail__rule-label-wrapper store-detail__rule-label-wrapper--narrow">
            <text class="store-detail__rule-label">加人</text>
          </view>
          <view class="store-detail__rule-value">
            <view class="store-detail__rule-value-inner">
              <text class="store-detail__rule-value-text">标准入住6人，不可加人</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Other rules (x=16, y=196, width=311px, height=24px) -->
      <view class="store-detail__other-rules">
        <view class="store-detail__other-label-wrapper">
          <text class="store-detail__other-label">其他</text>
        </view>
        <view class="store-detail__other-content">
          <view class="store-detail__other-tag-wrapper">
            <!-- 接待港澳台标签 (width=132px, height=10px) -->
          </view>
          <view class="store-detail__other-text-wrapper">
            <text class="store-detail__other-text">请仔细阅读房东其他要求</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 体验流程卡片 (activeTab === 'process') - height=461px (922rpx) -->
    <view class="store-detail__process-card" wx:if="{{activeTab === 'process'}}">
      <!-- Header (x=16, y=16, width=311px) -->
      <view class="store-detail__process-header">
        <view class="store-detail__process-title-wrapper">
          <text class="store-detail__process-title">体验流程</text>
        </view>
        <view class="store-detail__process-link" bindtap="onViewAllProcess">
          <text class="store-detail__process-link-text">全部流程</text>
          <image
            class="store-detail__arrow-right-icon"
            src="/images/store-detail/angle-right-small.svg"
            mode="aspectFit"
          ></image>
        </view>
      </view>

      <!-- Tip container (x=16, y=52, width=311px) -->
      <view class="store-detail__process-tip">
        <view class="store-detail__info-icon-wrapper">
          <image class="store-detail__info-icon" src="/images/store-detail/info-circle.svg" mode="aspectFit"></image>
        </view>
        <text class="store-detail__process-tip-text">以下规则由房东制定，请仔细阅读并遵守</text>
      </view>

      <!-- Process container (x=16, y=76, width=311px, height=120px, padding=12px 0) -->
      <view class="store-detail__process-list">
        <!-- 入离 -->
        <view class="store-detail__process-row">
          <view class="store-detail__process-label-wrapper">
            <text class="store-detail__process-label">入离</text>
          </view>
          <view class="store-detail__process-value">
            <text class="store-detail__process-text">14:00-24:00入住, 12:00前退房</text>
          </view>
        </view>

        <!-- Line (width=311px, height=1px) -->
        <view class="store-detail__process-divider"></view>

        <!-- 退订 -->
        <view class="store-detail__process-row">
          <view class="store-detail__process-label-wrapper store-detail__process-label-wrapper--narrow">
            <text class="store-detail__process-label">退订</text>
          </view>
          <view class="store-detail__process-value-col">
            <view class="store-detail__process-value-item">
              <text class="store-detail__process-text store-detail__process-text--green">30分钟内免费取消</text>
            </view>
            <view class="store-detail__process-value-item">
              <text class="store-detail__process-text-small">订单确认30分钟后, 取消订单将扣除全部房费</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Refund table (x=16, y=195, width=311px, height=141px) -->
      <view class="store-detail__refund-table">
        <!-- 表头背景 (height=40px, x=1, y=1, width=309px) -->
        <view class="store-detail__refund-header-bg"></view>

        <!-- Header (x=12, y=12, width=287px, height=17px) -->
        <view class="store-detail__refund-header">
          <view class="store-detail__refund-header-left">
            <text class="store-detail__refund-header-text">退订时间</text>
          </view>
          <view class="store-detail__refund-header-right">
            <text class="store-detail__refund-header-text">退订费用</text>
          </view>
        </view>

        <!-- Body (x=12, y=41, width=287px, height=64px) -->
        <view class="store-detail__refund-body">
          <!-- Row 1 (y=12) -->
          <view class="store-detail__refund-row">
            <view class="store-detail__refund-time">
              <view class="store-detail__refund-badge">
                <text class="store-detail__refund-badge-text">当前阶段</text>
              </view>
              <text class="store-detail__refund-text">预订成功后30分钟内</text>
            </view>
            <view class="store-detail__refund-fee">
              <text class="store-detail__refund-text">免费取消</text>
            </view>
          </view>

          <!-- Row 2 (y=64) -->
          <view class="store-detail__refund-row store-detail__refund-row--last">
            <view class="store-detail__refund-time-simple">
              <text class="store-detail__refund-text">11月19日16:21后</text>
            </view>
            <view class="store-detail__refund-fee-simple">
              <text class="store-detail__refund-text">取消扣全款</text>
            </view>
          </view>
        </view>

        <!-- Bottom divider (y=98, height=1px, x=1, width=310px) -->
        <view class="store-detail__refund-divider"></view>
      </view>

      <!-- Requirements (x=16, y=368, width=311px, padding=17px 0 0) -->
      <view class="store-detail__requirement-section">
        <view class="store-detail__requirement-label-wrapper">
          <text class="store-detail__requirement-label">要求</text>
        </view>
        <view class="store-detail__requirement-content">
          <!-- Row 1 (y=50) -->
          <view class="store-detail__requirement-row">
            <view class="store-detail__requirement-item">
              <image
                class="store-detail__check-icon"
                src="/images/store-detail/check-circle.svg"
                mode="aspectFit"
              ></image>
              <text class="store-detail__requirement-text">接待婴儿</text>
            </view>
            <view class="store-detail__requirement-item">
              <image
                class="store-detail__check-icon"
                src="/images/store-detail/check-circle.svg"
                mode="aspectFit"
              ></image>
              <text class="store-detail__requirement-text">接待儿童</text>
            </view>
          </view>

