<view class="store-detail">
  <!-- 状态栏占位 -->
  <status-bar />

  <!-- Header - 滚动超过100px后显示白色背景 -->
  <view class="store-detail__header {{showHeaderBg ? 'store-detail__header--visible' : ''}}">
    <status-bar />

    <!-- Header Actions -->
    <view class="store-detail__header-actions">
      <!-- 左侧: 返回按钮 (32x32px) -->
      <view class="store-detail__back-btn" bindtap="onGoBack">
        <image class="store-detail__back-icon" src="/images/store-detail/back-btn.svg" mode="aspectFit"></image>
      </view>

      <!-- 中间: 喜欢和分享按钮组 -->
      <view class="store-detail__actions-group">
        <!-- 收藏组 (width=56px, height=49px) -->
        <view class="store-detail__favorite-wrapper">
          <!-- Like button (40x40px) -->
          <view class="store-detail__favorite-btn" bindtap="onToggleFavorite">
            <image class="store-detail__favorite-icon" src="/images/store-detail/heart-icon.svg" mode="aspectFit">
            </image>
          </view>
          <!-- Badge (34x22px) -->
          <view class="store-detail__favorite-badge">
            <text class="store-detail__favorite-count">{{favoriteCount}}</text>
          </view>
        </view>

        <!-- Share button (40x40px) -->
        <view class="store-detail__share-btn" bindtap="onShare">
          <image class="store-detail__share-icon" src="/images/store-detail/share-btn.svg" mode="aspectFit"></image>
        </view>
      </view>

      <!-- 右侧占位,保持平衡 -->
      <view class="store-detail__placeholder"></view>
    </view>

    <!-- 标签导航栏 - 滚动超过100px后显示 -->
    <t-tabs wx:if="{{showHeaderBg}}" value="{{activeTab}}" bind:change="onTabChange" theme="line"
      class="store-detail__tabs">
      <t-tab-panel wx:for="{{tabs}}" wx:key="id" label="{{item.name}}" value="{{item.id}}" />
    </t-tabs>
  </view>

  <!-- Container (y=157px, padding=16px) - 所有内容从上到下排列 -->
  <view class="store-detail__container">
    <!-- Section 1: 概览 -->
    <view id="overview-section" class="store-detail__section" data-tab="overview">
      <overview-tab bind:videoTour="onVideoTour" bind:viewMap="onViewMap" bind:viewReviews="onViewReviews" />
    </view>

    <!-- Section 2: 房源 -->
    <view id="listing-section" class="store-detail__section" data-tab="listing">
      <listing-tab bind:bookRoom="onBookRoom" bind:couponVerify="onCouponVerify" bind:balance="onBalance"
        bind:wifi="onWifi" bind:selectDate="onSelectDate" bind:viewCoupons="onViewCoupons" />
    </view>

    <!-- Section 3: 点评 -->
    <view id="review-section" class="store-detail__section" data-tab="review">
      <review-tab bind:viewAll="onViewAllReviews" />
    </view>

    <!-- Section 4: 特点 -->
    <view id="feature-section" class="store-detail__section" data-tab="feature">
      <feature-tab bind:expand="onExpandFeature" />
    </view>

    <!-- Section 5: 设施 -->
    <view id="facility-section" class="store-detail__section" data-tab="facility">
      <facility-tab bind:viewAll="onViewAllFacilities" />
    </view>

    <!-- Section 6: 房东 -->
    <view id="landlord-section" class="store-detail__section" data-tab="landlord">
      <landlord-tab landlordData="{{landlordData}}" bind:viewPage="onViewLandlordPage"
        bind:contact="onContactLandlord" />

      <!-- 体验流程简版卡片 (房东介绍下方) -->
      <view class="store-detail__process-simple-card">
        <view class="store-detail__process-simple-header">
          <text class="store-detail__process-simple-title">体验流程</text>
          <view class="store-detail__process-simple-link" bindtap="onViewAllProcess">
            <text class="store-detail__process-simple-link-text">全部流程 </text>
            <image class="store-detail__arrow-right-icon" src="/images/store-detail/angle-right-small.svg"
              mode="aspectFit"></image>
          </view>
        </view>
        <view class="store-detail__process-simple-tip">
          <view class="store-detail__info-icon-wrapper">
            <text class="store-detail__info-icon-text"></text>
          </view>
          <text class="store-detail__process-simple-tip-text">以下规则由房东制定,请仔细阅读并遵守</text>
        </view>
      </view>
    </view>

    <!-- Section 7: 体验流程 -->
    <view id="process-section" class="store-detail__section" data-tab="process">
      <process-tab bind:viewAll="onViewAllProcess" />
    </view>

    <!-- Section 8: 费用须知 -->
    <view id="cost-section" class="store-detail__section" data-tab="cost">
      <cost-tab costRules="{{costRules}}" bind:viewAll="onViewAllRules" />

      <!-- 温馨提示 -->
      <view class="store-detail__tip-section">
        <view class="store-detail__tip-container">
          <text class="store-detail__tip-text">温馨提示：民宿不能聚会吵闹，不能做饭。因深圳天气炎热...</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 预订按钮 -->
  <booking-footer checkinDate="住 11-19" checkoutDate="离 11-20" currentPrice="{{468}}" originalPrice="{{669}}"
    bind:selectDate="onSelectDate" bind:sceneSelection="onSceneSelection" bind:bookNow="onBookNow" />

  <!-- 登录弹窗 -->
  <login-popup visible="{{showLoginPopup}}" bind:visiblechange="onLoginPopupVisibleChange"
    bind:loginsuccess="onLoginSuccess" />
</view>
