<!-- 体验流程模块 - Figma node-id=107-2109 -->
<view class="process-tab">
  <!-- 头部区域 -->
  <view class="process-tab__header">
    <view class="process-tab__title-wrapper">
      <text class="process-tab__title">体验流程</text>
    </view>
    <view class="process-tab__link" bindtap="onViewAllProcess">
      <text class="process-tab__link-text">全部流程</text>
      <image
        class="process-tab__arrow-icon"
        src="/assets/figma/cost-notice/icon-angle-right-small.svg"
        mode="aspectFit"
      />
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="process-tab__tip">
    <image class="process-tab__tip-icon" src="/images/store-detail/info-circle.svg" mode="aspectFit" />
    <text class="process-tab__tip-text">以下规则由房东制定，请仔细阅读并遵守</text>
  </view>

  <!-- 规则列表 -->
  <view class="process-tab__rules">
    <!-- 入离 -->
    <view class="process-tab__rule-item">
      <view class="process-tab__rule-label">
        <text class="process-tab__rule-label-text">入离</text>
      </view>
      <view class="process-tab__rule-value">
        <text class="process-tab__rule-value-text">14:00-24:00入住, 12:00前退房</text>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="process-tab__divider" />

    <!-- 退订 -->
    <view class="process-tab__rule-item">
      <view class="process-tab__rule-label process-tab__rule-label--narrow">
        <text class="process-tab__rule-label-text">退订</text>
      </view>
      <view class="process-tab__rule-value process-tab__rule-value--column">
        <text class="process-tab__rule-value-green">30分钟内免费取消</text>
        <text class="process-tab__rule-value-small">订单确认30分钟后, 取消订单将扣除全部房费</text>
      </view>
    </view>
  </view>

  <!-- 退订表格 -->
  <view class="process-tab__refund-table">
    <!-- 表头背景 -->
    <view class="process-tab__table-header-bg" />

    <!-- 表头 -->
    <view class="process-tab__table-header">
      <text class="process-tab__table-th-text">退订时间</text>
      <text class="process-tab__table-th-text">退订费用</text>
    </view>

    <!-- 表体 -->
    <view class="process-tab__table-body">
      <!-- 第一行：当前阶段badge -->
      <view class="process-tab__table-row">
        <view class="process-tab__current-badge">
          <text class="process-tab__current-badge-text">当前阶段</text>
        </view>
      </view>

      <!-- 第二行：预订成功后30分钟内 + 免费取消 -->
      <view class="process-tab__table-row">
        <text class="process-tab__table-text">预订成功后30分钟内</text>
        <text class="process-tab__table-text">免费取消</text>
      </view>

      <!-- 分割线 -->
      <view class="process-tab__table-divider" />

      <!-- 第三行：11月19日16:21后 + 取消扣全款 -->
      <view class="process-tab__table-row">
        <text class="process-tab__table-text">11月19日16:21后</text>
        <text class="process-tab__table-text">取消扣全款</text>
      </view>
    </view>
  </view>

  <!-- 要求区域 -->
  <view class="process-tab__requirements">
    <view class="process-tab__requirements-label">
      <text class="process-tab__requirements-label-text">要求</text>
    </view>
    <view class="process-tab__requirements-content">
      <!-- 第三行 -->
      <view class="process-tab__requirements-row">
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-check-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">接待婴儿</text>
        </view>
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-check-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">接待儿童</text>
        </view>
      </view>

      <!-- 第二行 -->
      <view class="process-tab__requirements-row">
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-xmark-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">接待老人</text>
        </view>
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-check-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">接待海外</text>
        </view>
      </view>

      <!-- 第一行 -->
      <view class="process-tab__requirements-row">
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-check-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">接待港澳台</text>
        </view>
        <view class="process-tab__requirement-item">
          <image
            class="process-tab__requirement-icon"
            src="/assets/figma/process-tab/icon-xmark-circle.svg"
            mode="aspectFit"
          />
          <text class="process-tab__requirement-text">带宠物</text>
        </view>
      </view>
    </view>
  </view>
</view>
