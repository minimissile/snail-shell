<!-- 费用须知模块 - Figma node-id=113-1153 -->
<view class="cost-tab">
  <!-- 头部区域 -->
  <view class="cost-tab__header">
    <view class="cost-tab__title-wrapper">
      <text class="cost-tab__title">费用须知</text>
    </view>
    <view class="cost-tab__link" bindtap="onViewAllRules">
      <text class="cost-tab__link-text">全部须知</text>
      <image class="cost-tab__arrow-icon" src="/assets/figma/cost-notice/icon-angle-right-small.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="cost-tab__tip">
    <image class="cost-tab__tip-icon" src="/images/store-detail/info-circle.svg" mode="aspectFit" />
    <text class="cost-tab__tip-text">以下规则由房东制定，请仔细阅读并遵守</text>
  </view>

  <!-- 规则列表 -->
  <view class="cost-tab__rules">
    <!-- 押金 -->
    <view class="cost-tab__rule-item">
      <view class="cost-tab__rule-label">
        <text class="cost-tab__rule-label-text">押金</text>
      </view>
      <view class="cost-tab__rule-value">
        <image class="cost-tab__info-icon" src="/assets/figma/cost-notice/icon-info-circle.svg" mode="aspectFit" />
        <text class="cost-tab__rule-value-text"
          >¥{{costRules.deposit.amount}}，下单后入住前通过平台支付，离店后{{'\n'}}原路退还，无纠纷不扣押</text
        >
      </view>
    </view>

    <!-- 分割线 -->
    <view class="cost-tab__divider" />

    <!-- 加人 -->
    <view class="cost-tab__rule-item">
      <view class="cost-tab__rule-label cost-tab__rule-label--narrow">
        <text class="cost-tab__rule-label-text">加人</text>
      </view>
      <view class="cost-tab__rule-value">
        <text class="cost-tab__rule-value-simple">{{costRules.extraPerson.text}}</text>
      </view>
    </view>
  </view>

  <!-- 其他规则 -->
  <view class="cost-tab__other">
    <view class="cost-tab__other-label">
      <text class="cost-tab__other-label-text">其他</text>
    </view>
    <view class="cost-tab__other-value">
      <text class="cost-tab__other-value-text">请仔细阅读房东其他要求</text>
    </view>
  </view>
</view>
