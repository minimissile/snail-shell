<view class="page" aria-label="常用信息">
  <view class="content" aria-label="内容">
    <view class="card" bindtap="onOpenCard" aria-role="button" aria-label="常用信息卡片">
      <view class="card__main">
        <text class="card__name">{{name}}</text>
        <view class="card__rows" aria-label="信息列表">
          <view class="card__row">
            <text class="card__label">手机号</text>
            <text class="card__value">{{phone}}</text>
          </view>
          <view class="card__row">
            <text class="card__label">身份证</text>
            <text class="card__value">{{idCard}}</text>
          </view>
        </view>
      </view>

      <view class="card__chevron" aria-hidden="true"></view>
    </view>
  </view>

  <view class="footer" aria-label="底部操作">
    <button class="cta" bindtap="onAddTraveler" aria-label="添加常用旅客">添加常用旅客</button>
  </view>
</view>
