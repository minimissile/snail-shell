<view class="page" aria-label="常用信息">
  <navigation-bar extClass="common-nav" title="" back="{{false}}" color="#000000" background="transparent">
    <view slot="left" class="topbar-main" aria-label="返回与标题">
      <view
        class="icon icon--back"
        bindtap="onBack"
        aria-role="button"
        aria-label="返回"
      >
        <image class="icon__img" src="/assets/figma/common-info-back.svg" mode="aspectFit" aria-hidden="true" />
      </view>
      <text class="topbar-title">常用信息</text>
    </view>

    <view slot="right" class="topbar-right" aria-label="操作">
      <view class="topbar-actions">
        <view
          class="topbar-action"
          bindtap="onMenu"
          aria-role="button"
          aria-label="菜单"
        >
          <text class="topbar-action__text">⋯</text>
        </view>
        <view class="topbar-divider" aria-hidden="true"></view>
        <view
          class="topbar-action"
          bindtap="onClose"
          aria-role="button"
          aria-label="关闭"
        >
          <image
            class="topbar-close"
            src="/assets/figma/common-info-close.svg"
            mode="aspectFit"
            aria-hidden="true"
          />
        </view>
      </view>
    </view>
  </navigation-bar>

  <view class="content" aria-label="内容">
    <view class="card" bindtap="onOpenCard" aria-role="button" aria-label="常用信息卡片">
      <view class="card__main">
        <text class="card__name">{{name}}</text>
        <view class="card__rows" aria-label="信息列表">
          <view class="card__row">
            <text class="card__label">手机号</text>
            <text class="card__value">{{phone}}</text>
          </view>
          <view class="card__row">
            <text class="card__label">身份证</text>
            <text class="card__value">{{idCard}}</text>
          </view>
        </view>
      </view>

      <view class="card__chevron" aria-hidden="true">
        <image
          class="card__chevron-icon"
          src="/assets/figma/common-info-chevron-right.svg"
          mode="aspectFit"
        />
      </view>
    </view>
  </view>

  <view class="footer" aria-label="底部操作">
    <button class="cta" bindtap="onAddTraveler" aria-label="添加常用旅客">添加常用旅客</button>
  </view>
</view>
