<!--index.wxml-->
<scroll-view class="home-scroll" scroll-y type="list" enable-back-to-top>
  <view class="home">
    <view class="home__header" catchtap="onHeaderTap">
      <view class="home__header-overlay"></view>
      <navigation-bar title="" back="{{false}}" color="#FFFFFF" background="transparent"></navigation-bar>
      <view class="home__title-wrap">
        <text class="home__title">订青旅 上蜗壳</text>
        <text class="home__subtitle">寻找青年之家</text>
      </view>
    </view>

    <view class="home__content">
      <!-- 搜索条件 -->
      <view class="booking-card" aria-label="订房搜索">
        <view class="booking-card__row booking-card__row--border">
          <view class="booking-card__route">
            <text class="booking-card__route-city" bindtap="onSelectCity">{{fromCity}}</text>
            <image class="booking-card__route-icon" src="/assets/figma/home-route-icon-1.svg" mode="aspectFit" />
            <image
              class="booking-card__route-icon booking-card__route-icon--wide"
              src="/assets/figma/home-route-icon-2.svg"
              mode="aspectFit"
            />
            <input
              class="booking-card__route-input"
              type="text"
              placeholder="请输入目的地"
              value="{{toPlace}}"
              bindinput="onInputDestination"
              bindfocus="onInputFocus"
              bindblur="onInputBlur"
              placeholder-class="booking-card__route-placeholder"
              confirm-type="search"
              bindconfirm="onSearch"
              cursor-spacing="20"
            />
          </view>
          <view class="booking-card__route-actions">
            <view
              class="booking-card__icon-btn"
              wx:if="{{toPlace}}"
              catchtap="onClearToPlace"
              aria-role="button"
              aria-label="清除目的地"
            >
              <image class="booking-card__icon" src="/assets/figma/home-close.svg" mode="aspectFit" />
            </view>
            <view class="booking-card__route-spacer"></view>
            <view class="booking-card__locate" catchtap="onUseMyLocation" aria-role="button" aria-label="使用我的位置">
              <image
                class="booking-card__icon booking-card__icon--gps"
                src="/assets/figma/home-gps.svg"
                mode="aspectFit"
              />
              <text class="booking-card__locate-text">我的位置</text>
            </view>
          </view>
        </view>

        <view class="booking-card__row booking-card__row--border" bindtap="onOpenDatePicker">
          <view class="booking-card__dates">
            <view class="booking-card__date">
              <text class="booking-card__date-main">{{checkInDateMain}}</text>
              <text class="booking-card__date-sub">{{checkInDateSub}}</text>
            </view>
            <text class="booking-card__date-dash">-</text>
            <view class="booking-card__date">
              <text class="booking-card__date-main">{{checkOutDateMain}}</text>
              <text class="booking-card__date-sub">{{checkOutDateSub}}</text>
            </view>
          </view>
          <text class="booking-card__nights">共{{nights}}晚</text>
        </view>

        <view class="booking-card__row booking-card__row--border booking-card__row--meta">
          <view class="booking-card__meta" bindtap="onOpenPeoplePicker" aria-role="button" aria-label="选择人数和床数">
            <text class="booking-card__meta-text">人数 / 床数</text>
            <image class="booking-card__meta-icon" src="/assets/figma/home-caret-down.svg" mode="aspectFit" />
          </view>
          <view class="booking-card__meta-divider"></view>
          <view class="booking-card__meta" bindtap="onOpenPricePicker" aria-role="button" aria-label="选择价格">
            <text class="booking-card__price-text">价格</text>
          </view>
        </view>

        <view class="booking-card__chips" aria-label="热门筛选">
          <scroll-view class="booking-card__chips-scroll" scroll-x show-scrollbar="{{false}}">
            <view class="booking-card__chips-inner">
              <view class="booking-card__chip booking-card__chip--points" bindtap="onPointsTap">
                <image class="booking-card__chip-icon" src="/assets/figma/home-points.png" mode="aspectFit" />
                <text class="booking-card__chip-points-text">积分当钱花</text>
              </view>
              <view class="booking-card__chip" bindtap="onChipTap" data-place="福田区">
                <text class="booking-card__chip-text">福田区</text>
              </view>
              <view class="booking-card__chip" bindtap="onChipTap" data-place="南山区">
                <text class="booking-card__chip-text">南山区</text>
              </view>
              <view class="booking-card__chip" bindtap="onChipTap" data-place="深圳北站">
                <text class="booking-card__chip-text">深圳北站</text>
              </view>
              <view class="booking-card__chip booking-card__chip--pill" bindtap="onChipTap" data-place="深圳罗">
                <text class="booking-card__chip-text">深圳罗</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <button class="booking-card__search-btn" bindtap="onSearch" disabled="{{isSearching}}" aria-label="开始搜索">
          <text class="booking-card__search-text">开始搜索</text>
        </button>
      </view>

      <!-- 三大入口 -->
      <view class="promo-row" aria-label="促销入口">
        <view class="promo promo--house" aria-label="品质好房">
          <text class="promo__title">品质好房</text>
          <text class="promo__desc">平台验真 入住无忧</text>
          <image class="promo__image promo__image--house" src="/assets/figma/home-promo-house.png" mode="aspectFill" />
          <view class="promo__link" bindtap="onGoSelectRoom" aria-role="button" aria-label="去选房">
            <text class="promo__link-text">去选房</text>
          </view>
        </view>

        <view class="promo promo--redpacket" aria-label="百元红包">
          <text class="promo__title">百元红包</text>
          <text class="promo__desc">社群专属福利</text>
          <view class="promo__badge promo__badge--red"></view>
          <image
            class="promo__image promo__image--redpacket"
            src="/assets/figma/home-promo-redpacket.png"
            mode="aspectFit"
          />
        </view>

        <view class="promo promo--groupbuy" aria-label="团购验券" bindtap="onGoGroupBuy">
          <text class="promo__title">团购验券</text>
          <text class="promo__desc">订青旅折上折</text>
          <view class="promo__badge promo__badge--yellow"></view>
          <image
            class="promo__image promo__image--groupbuy"
            src="/assets/figma/home-promo-groupbuy.png"
            mode="aspectFill"
          />
        </view>
      </view>

      <image
        class="invite-banner"
        src="/assets/figma/home-invite-banner.jpg"
        mode="aspectFill"
        aria-label="邀请好友活动"
      />

      <view class="recommend-title" aria-label="推荐区域">
        <text class="recommend-title__text">
          安<text class="recommend-title__highlight">心</text>订 · 省<text class="recommend-title__highlight">心</text
          >住
        </text>
      </view>
    </view>
  </view>
</scroll-view>

