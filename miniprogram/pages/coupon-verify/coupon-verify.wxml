<view class="coupon-verify-page">
  <!-- 门店信息区 -->
  <view class="store-info">
    <view class="store-info__content">
      <view class="store-info__main">
        <view class="store-info__heading">
          <text class="store-info__name">{{storeName}}</text>
        </view>
        <view class="store-info__location">
          <image class="store-info__location-icon" src="/images/location-pin-line.svg" mode="aspectFit" />
          <view class="store-info__location-wrapper">
            <text class="store-info__distance">距离您: {{distance}}</text>
          </view>
        </view>
      </view>
      <view class="store-info__action">
        <view class="store-info__button" bindtap="onChangeStore">
          <text class="store-info__button-text">更换门店</text>
          <view class="store-info__button-icon">
            <view class="store-info__button-icon-wrapper">
              <text class="store-info__button-symbol"></text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 主要内容区 -->
  <view class="main-content">
    <!-- 券码验证标题和识图按钮 -->
    <view class="verify-section">
      <view class="verify-section__header">
        <text class="verify-section__title">券码验证</text>
      </view>
      <view class="verify-button" bindtap="onImageRecognition">
        <image class="verify-button__icon" src="/images/group-749.svg" mode="aspectFit" />
        <view class="verify-button__text-wrapper">
          <text class="verify-button__text">识图验券</text>
        </view>
      </view>
    </view>

    <!-- 核销流程说明 -->
    <view class="process-card">
      <view class="process-card__tag">
        <text class="process-card__tag-text">核销流程</text>
      </view>

      <!-- 步骤1 -->
      <view class="process-card__step">
        <view class="process-card__step-content">
          <text class="process-card__step-text">1.打开美团/抖音/大众点评APP{{'\n'}}截图保存-团购核销二维码</text>
        </view>
        <image class="process-card__step-image" src="/images/group-749.svg" mode="aspectFit" />
      </view>

      <!-- 分隔线1 -->
      <view class="process-card__divider">
        <view class="process-card__divider-wrapper">
          <text class="process-card__divider-icon"></text>
        </view>
      </view>

      <!-- 步骤2 -->
      <view class="process-card__step">
        <view class="process-card__step-content">
          <text class="process-card__step-text">2.点击上方-[识图验券]按钮</text>
        </view>
        <view class="process-card__step-button">
          <view class="process-card__step-button-bg"></view>
          <view class="process-card__step-button-rect"></view>
          <view class="process-card__step-button-content">
            <image class="process-card__step-button-icon" src="/images/group-749.svg" mode="aspectFit" />
            <view class="process-card__step-button-text-wrapper">
              <text class="process-card__step-button-text">识图验券</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 分隔线2 -->
      <view class="process-card__divider">
        <view class="process-card__divider-wrapper">
          <text class="process-card__divider-icon"></text>
        </view>
      </view>

      <!-- 步骤3 -->
      <view class="process-card__step">
        <view class="process-card__step-content">
          <text class="process-card__step-text">3.选择相册-识别团购二维码</text>
        </view>
        <view class="process-card__step-album">
          <view class="process-card__step-album-bg"></view>
          <text class="process-card__step-album-text">相册</text>
          <image class="process-card__step-album-icon" src="/images/gallery-icon.svg" mode="aspectFit" />
        </view>
      </view>
    </view>

    <!-- 兑换帮助 -->
    <view class="help-section">
      <view class="help-section__content">
        <view class="help-section__title-wrapper">
          <text class="help-section__title">兑换帮助</text>
        </view>
        <view class="help-section__text-wrapper">
          <text class="help-section__text">1.请注意所选门店是否为需用入住的门店，以免误选无法办理入住。</text>
        </view>
      </view>
    </view>
  </view>
</view>
