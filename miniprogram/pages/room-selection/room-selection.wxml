<view class="room-selection">
  <!-- 状态栏占位 -->
  <view class="room-selection__status-bar"></view>

  <!-- 导航栏头部 -->
  <view class="room-selection__header">
    <!-- 返回和收藏/分享按钮 -->
    <view class="room-selection__header-top">
      <view class="room-selection__back-btn" bindtap="onGoBack">
        <image class="room-selection__back-icon" src="/assets/figma/room-selection/icon-back.svg" mode="aspectFit" />
      </view>

      <view class="room-selection__header-actions">
        <view class="room-selection__favorite-group">
          <view class="room-selection__favorite-btn" bindtap="onToggleFavorite">
            <image
              class="room-selection__favorite-icon"
              src="/assets/figma/room-selection/icon-favorite.svg"
              mode="aspectFit"
            />
          </view>
          <view class="room-selection__favorite-badge">
            <text class="room-selection__favorite-count">{{favoriteCount}}</text>
          </view>
        </view>

        <!-- 分享按钮 -->
        <view class="room-selection__share-btn" bindtap="onShare">
          <image
            class="room-selection__share-icon"
            src="/assets/figma/room-selection/icon-share.svg"
            mode="aspectFit"
          />
        </view>
      </view>
    </view>

    <!-- 门店名称和营业时间 -->
    <view class="room-selection__nav">
      <text class="room-selection__store-name">{{storeName}}</text>
      <view class="room-selection__nav-spacer"></view>
      <text class="room-selection__business-hours">{{businessHours}}</text>
    </view>

    <!-- 预订方式切换 -->
    <view class="room-selection__booking-mode">
      <view class="room-selection__booking-label">
        <text class="room-selection__booking-label-text">预定方式</text>
        <view class="room-selection__booking-info-icon" bindtap="onViewBookingInfo">
          <view class="room-selection__info-circle"></view>
        </view>
      </view>

      <view class="room-selection__booking-tabs">
        <view
          class="room-selection__booking-tab {{bookingMode === 'day' ? 'room-selection__booking-tab--active' : ''}}"
          data-mode="day"
          bindtap="onSwitchBookingMode"
        >
          <text class="room-selection__booking-tab-text">按天</text>
        </view>
        <view
          class="room-selection__booking-tab {{bookingMode === 'hour' ? 'room-selection__booking-tab--active' : ''}}"
          data-mode="hour"
          bindtap="onSwitchBookingMode"
        >
          <text class="room-selection__booking-tab-text">按小时</text>
        </view>
        <view
          class="room-selection__booking-tab {{bookingMode === 'month' ? 'room-selection__booking-tab--active' : ''}}"
          data-mode="month"
          bindtap="onSwitchBookingMode"
        >
          <text class="room-selection__booking-tab-text">按月</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 日期选择区域 -->
  <view class="room-selection__date-section">
    <text class="room-selection__section-label">预定日期</text>

    <view class="room-selection__date-picker">
      <view class="room-selection__date-input" bindtap="onChangeStartDate">
        <text class="room-selection__date-value">{{startDate}}</text>
        <text class="room-selection__date-week">{{startDayOfWeek}}</text>
      </view>

      <text class="room-selection__date-separator">至</text>

      <view class="room-selection__date-input" wx:if="{{bookingMode !== 'month'}}" bindtap="onChangeEndDate">
        <text class="room-selection__date-value">{{endDate}}</text>
        <text class="room-selection__date-week">{{endDayOfWeek}}</text>
      </view>
    </view>
  </view>

  <!-- 按小时 - 时段选择 -->
  <view class="room-selection__time-section" wx:if="{{bookingMode === 'hour'}}">
    <text class="room-selection__section-label">预定时段</text>

    <view class="room-selection__time-picker">
      <view class="room-selection__time-input" bindtap="onChangeStartTime">
        <text class="room-selection__time-value">{{startTime}}</text>
        <image class="room-selection__time-icon" src="/images/room-selection/icon-sort.svg" />
      </view>

      <text class="room-selection__time-separator">至</text>

      <view class="room-selection__time-input" bindtap="onChangeEndTime">
        <text class="room-selection__time-value">{{endTime}}</text>
        <image class="room-selection__time-icon" src="/images/room-selection/icon-sort.svg" />
      </view>
    </view>
  </view>

  <!-- 按月 - 月份选择 -->
  <view class="room-selection__month-section" wx:if="{{bookingMode === 'month'}}">
    <text class="room-selection__section-label">选择月份</text>

    <view class="room-selection__month-picker">
      <view class="room-selection__month-input" bindtap="onChangeMonth">
        <text class="room-selection__month-value">{{monthCount}}</text>
        <image class="room-selection__month-icon" src="/images/room-selection/icon-sort.svg" />
      </view>

      <text class="room-selection__month-separator">至</text>

      <view class="room-selection__month-end-wrapper">
        <text class="room-selection__month-end-label">结束日期</text>
        <text class="room-selection__month-end-value">{{monthEndDate}}</text>
      </view>
    </view>
  </view>

  <!-- 已选信息提示 -->
  <view class="room-selection__selected-info">
    <view class="room-selection__selected-item">
      <view class="room-selection__info-icon" bindtap="onViewSelectedInfo"></view>
      <text class="room-selection__selected-text"
        >已选:{{bookingMode === 'day' ? selectedDays : bookingMode === 'hour' ? selectedHours : selectedMonths}}</text
      >
    </view>

    <view class="room-selection__booking-tip">
      <view class="room-selection__clock-icon"></view>
      <text class="room-selection__tip-text">{{bookingTip}}</text>
    </view>
  </view>

  <!-- 床位图例 -->
  <view class="room-selection__legend">
    <view class="room-selection__legend-items">
      <view class="room-selection__legend-item">
        <view class="room-selection__legend-color room-selection__legend-color--selected"></view>
        <text class="room-selection__legend-label">当前已选</text>
      </view>
      <view class="room-selection__legend-item">
        <view class="room-selection__legend-color room-selection__legend-color--available"></view>
        <text class="room-selection__legend-label">可选</text>
      </view>
      <view class="room-selection__legend-item">
        <view class="room-selection__legend-color room-selection__legend-color--unavailable"></view>
        <text class="room-selection__legend-label">不可选</text>
      </view>
    </view>

    <view class="room-selection__price-info-btn" bindtap="onViewPriceInfo">
      <text class="room-selection__price-info-text">价格说明</text>
    </view>
  </view>

  <!-- 床位选择区域 -->
  <view class="room-selection__beds-container">
    <!-- 背景 -->
    <view class="room-selection__beds-bg"></view>
    <!-- 中间分割线 -->
    <view class="room-selection__beds-divider"></view>

    <!-- 床位组 B (左侧上) -->
    <view class="room-selection__bed-group" style="left: 24rpx; top: 32rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[0].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[0].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="0"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[0].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[0].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[0].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="0"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[0].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[0].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[0].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="0"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[0].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[0].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[0].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="0"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[0].beds[2].id}}</text>
      </view>
    </view>

    <!-- 床位组 B2 (左侧中) -->
    <view class="room-selection__bed-group" style="left: 24rpx; top: 248rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[1].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[1].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="1"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[1].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[1].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[1].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="1"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[1].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[1].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[1].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="1"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[1].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[1].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[1].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="1"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[1].beds[2].id}}</text>
      </view>
    </view>

    <!-- 床位组 B3 (左侧下) -->
    <view class="room-selection__bed-group" style="left: 24rpx; top: 464rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[2].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[2].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="2"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[2].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[2].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[2].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="2"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[2].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[2].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[2].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="2"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[2].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[2].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[2].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="2"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[2].beds[2].id}}</text>
      </view>
    </view>

    <!-- 床位组 A (右侧上) -->
    <view class="room-selection__bed-group" style="left: 344rpx; top: 32rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[3].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[3].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="3"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[3].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[3].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[3].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="3"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[3].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[3].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[3].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="3"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[3].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[3].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[3].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="3"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[3].beds[2].id}}</text>
      </view>
    </view>

    <!-- 床位组 A2 (右侧中) -->
    <view class="room-selection__bed-group" style="left: 344rpx; top: 248rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[4].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[4].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="4"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[4].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[4].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[4].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="4"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[4].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[4].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[4].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="4"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[4].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[4].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[4].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="4"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[4].beds[2].id}}</text>
      </view>
    </view>

    <!-- 床位组 A3 (右侧下) -->
    <view class="room-selection__bed-group" style="left: 344rpx; top: 464rpx">
      <view class="room-selection__bed-frame"></view>
      <image class="room-selection__bed-upper" src="/assets/figma/room-selection/bed-upper.png" />
      <image class="room-selection__bed-lower" src="/assets/figma/room-selection/bed-lower.png" />
      <view class="room-selection__bed-separator"></view>

      <view
        class="room-selection__bed {{bedGroups[5].beds[1].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[5].beds[1].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 16rpx"
        data-group="5"
        data-bed="1"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[5].beds[1].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[5].beds[0].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[5].beds[0].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 16rpx"
        data-group="5"
        data-bed="0"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[5].beds[0].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[5].beds[3].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[5].beds[3].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 80rpx; top: 108rpx"
        data-group="5"
        data-bed="3"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[5].beds[3].id}}</text>
      </view>
      <view
        class="room-selection__bed {{bedGroups[5].beds[2].status === 'selected' ? 'room-selection__bed--selected' : ''}} {{bedGroups[5].beds[2].status === 'unavailable' ? 'room-selection__bed--unavailable' : ''}}"
        style="left: 180rpx; top: 108rpx"
        data-group="5"
        data-bed="2"
        bindtap="onToggleBed"
      >
        <text class="room-selection__bed-num">{{bedGroups[5].beds[2].id}}</text>
      </view>
    </view>
  </view>

  <!-- 已选床位卡片（取消选房状态） -->
  <view class="room-selection__selected-card" wx:if="{{selectedBeds.length > 0}}">
    <!-- 语音图标 -->
    <image
      class="room-selection__card-volume-icon"
      src="/assets/figma/room-selection/icon-volume.svg"
      mode="aspectFit"
      bindtap="onPlayAudio"
    />

    <!-- 智能门锁提示 -->
    <view class="room-selection__card-smart-lock">
      <text class="room-selection__card-smart-lock-text">{{smartLockTip}}</text>
    </view>

    <!-- 分割线1 -->
    <view class="room-selection__card-line1"></view>

    <!-- 房型名称 -->
    <text class="room-selection__card-room-type">{{roomType}}</text>

    <!-- 切换房型按钮 -->
    <view class="room-selection__card-switch" bindtap="onSwitchRoomType">
      <text class="room-selection__card-switch-text">切换房型</text>
      <text class="room-selection__card-switch-icon"></text>
    </view>

    <!-- 日期标签 -->
    <text class="room-selection__card-day">{{currentDay}}</text>

    <!-- 时间段 -->
    <text class="room-selection__card-time-range">{{roomDate}}</text>

    <!-- 分割线2 -->
    <view class="room-selection__card-line2"></view>

    <!-- 已选床位列表 -->
    <view class="room-selection__selected-beds">
      <view class="room-selection__bed-item" wx:for="{{selectedBeds}}" wx:key="id">
        <view class="room-selection__bed-bg"></view>
        <view class="room-selection__bed-info">
          <text class="room-selection__bed-number">{{item.id}}</text>
          <text class="room-selection__bed-price">¥{{item.price}}</text>
        </view>
        <view class="room-selection__bed-divider"></view>
        <view class="room-selection__bed-close" data-bed-id="{{item.id}}" bindtap="onCancelBed">
          <image
            class="room-selection__bed-close-icon"
            src="/assets/figma/room-selection/icon-close-circle.svg"
            mode="aspectFit"
          />
        </view>
      </view>
    </view>
  </view>

  <!-- 底部预订按钮 -->
  <view class="room-selection__footer">
    <t-button
      theme="primary"
      size="large"
      block
      shape="round"
      t-class="room-selection__book-btn-custom"
      bind:tap="onBookNow"
    >
      <view class="room-selection__book-btn-content">
        <text class="room-selection__book-btn-text">立即预订</text>
        <view class="room-selection__book-btn-price">
          <text class="room-selection__book-btn-total">¥{{totalPrice}}</text>
          <view class="room-selection__book-btn-original-wrapper">
            <text class="room-selection__book-btn-original">¥{{originalPrice}}</text>
          </view>
        </view>
      </view>
    </t-button>
  </view>
</view>
