<view class="store-album">
  <status-bar />

  <view class="store-album__header">
    <view class="store-album__header-content">
      <view class="store-album__back-btn" bindtap="onGoBack">
        <image class="store-album__back-icon" src="/images/store-detail/back-btn.svg" mode="aspectFit"></image>
      </view>

      <view class="store-album__title">
        <text class="store-album__title-text">{{storeName || '门店相册'}}</text>
      </view>

      <view class="store-album__placeholder"></view>
    </view>

    <scroll-view class="store-album__filter" scroll-x="true" enable-flex="true" show-scrollbar="false">
      <view
        wx:for="{{filterTabs}}"
        wx:key="key"
        class="store-album__filter-item {{activeFilter === item.key ? 'store-album__filter-item--active' : ''}}"
        bindtap="onFilterChange"
        data-key="{{item.key}}"
      >
        <text class="store-album__filter-name">{{item.name}}</text>
        <text class="store-album__filter-count">({{item.count}})</text>
      </view>
    </scroll-view>
  </view>

  <view class="store-album__content">
    <view wx:for="{{displaySections}}" wx:key="key" class="store-album__section" wx:for-index="sectionIndex">
      <view class="store-album__section-title">
        <text class="store-album__section-title-text">{{item.title}}</text>
        <text class="store-album__section-count">({{item.images.length}})</text>
      </view>

      <view class="store-album__grid">
        <view
          wx:for="{{item.images}}"
          wx:key="id"
          wx:for-index="imageIndex"
          class="store-album__grid-item"
          bindtap="onImageTap"
          data-section-index="{{sectionIndex}}"
          data-image-index="{{imageIndex}}"
        >
          <image class="store-album__image" src="{{item.url}}" mode="aspectFill" lazy-load="true"></image>
        </view>
      </view>
    </view>

    <view class="store-album__empty" wx:if="{{displaySections.length === 0 && !isLoading}}">
      <image class="store-album__empty-icon" src="/images/store-detail/empty-album.svg" mode="aspectFit" />
      <text class="store-album__empty-text">暂无照片</text>
    </view>
  </view>
</view>
