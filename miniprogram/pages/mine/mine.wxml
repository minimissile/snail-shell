<view class="page">
  <view class="header" aria-label="会员个人中心">
    <view class="header-bg" aria-hidden="true"></view>

    <profile-header avatar-src="{{avatarSrc}}" user-name="{{userName}}" bind:menu="onOpenHeaderMenu" />

    <membership-banner greeting="{{greeting}}" member-type="{{memberType}}" bind:benefit="onTapBenefit" />
  </view>

  <view class="content">
    <stats-card
      coupon-count="{{couponCount}}"
      bind:coupon="onTapCoupon"
      bind:favorites="onTapFavorites"
      bind:points="onTapPoints"
      bind:action="onTapQuickAction"
    />

    <!-- 金刚区 -->
    <icon-grid bind:item="onTapGridItem" />
  </view>
</view>

<!-- 智能开锁浮动按钮 -->
<floating-lock-button />

<!-- 登录弹窗 -->
<login-popup
  visible="{{showLoginPopup}}"
  bind:visiblechange="onLoginPopupVisibleChange"
  bind:loginsuccess="onLoginSuccess"
/>
