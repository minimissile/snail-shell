{
  "name": "miniprogram-ts-less-quickstart",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "concurrently -n server,admin -c blue,green \"npm run dev:server\" \"npm run dev:admin\"",
    "dev:server": "cd server && npm run start:dev",
    "dev:admin": "cd admin && npm run dev",
    "build": "npm run build:server && npm run build:admin",
    "build:server": "cd server && npm run build",
    "build:admin": "cd admin && npm run build",
    "format": "prettier --write \"miniprogram/**/*.{js,ts,json,wxml,wxss,less}\"",
    "format:check": "prettier --check \"miniprogram/**/*.{js,ts,json,wxml,wxss,less}\""
  },
  "keywords": [],
  "author": "",
  "license": "",
  "dependencies": {
    "tdesign-miniprogram": "^1.12.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "miniprogram-api-typings": "^2.8.3-1",
    "prettier": "^3.2.5"
  }
}
